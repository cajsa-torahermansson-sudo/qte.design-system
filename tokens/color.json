{
  "color": {
    "primitive": {
      "purple": {
        "50":  { "$type": "color", "$value": "#E2E1FF" },
        "100": { "$type": "color", "$value": "#AEA7FF" },
        "200": { "$type": "color", "$value": "#9A83F7" },
        "300": { "$type": "color", "$value": "#896CFC" },
        "400": { "$type": "color", "$value": "#7A59FC" },
        "500": { "$type": "color", "$value": "#7054E2" },
        "600": { "$type": "color", "$value": "#5519D5" },
        "700": { "$type": "color", "$value": "#2B116A" },
        "800": { "$type": "color", "$value": "#241143" },
        "900": { "$type": "color", "$value": "#170E23" }
      },
      "gray": {
        "50":  { "$type": "color", "$value": "#FDFCFC" },
        "100": { "$type": "color", "$value": "#FAF5F5" },
        "200": { "$type": "color", "$value": "#F3E8E8" },
        "300": { "$type": "color", "$value": "#CFCCD1" },
        "400": { "$type": "color", "$value": "#5F5273" },
        "500": { "$type": "color", "$value": "#2D203E" },
        "600": { "$type": "color", "$value": "#1C1524" }
      },
      "white":  { "$type": "color", "$value": "#FFFFFF" },
      "black":  { "$type": "color", "$value": "#000000" }
    },
    "bg": {
      "primary":   { "$type": "color", "$value": "{color.primitive.gray.100}" },
      "secondary": { "$type": "color", "$value": "{color.primitive.gray.200}" },
      "surface":   { "$type": "color", "$value": "{color.primitive.white}" },
      "dark":      { "$type": "color", "$value": "{color.primitive.purple.900}" },
      "cream":     { "$type": "color", "$value": "{color.primitive.purple.50}" }
    },
    "text": {
      "heading":    { "$type": "color", "$value": "{color.primitive.purple.800}" },
      "body":       { "$type": "color", "$value": "{color.primitive.gray.400}" },
      "on-dark":    { "$type": "color", "$value": "{color.primitive.gray.50}" },
      "link":       { "$type": "color", "$value": "{color.primitive.gray.400}" },
      "link-hover": { "$type": "color", "$value": "{color.primitive.purple.500}" }
    },
    "border": {
      "default": { "$type": "color", "$value": "{color.primitive.gray.500}" },
      "hover":   { "$type": "color", "$value": "{color.primitive.white}" }
    },
    "accent": {
      "primary": { "$type": "color", "$value": "{color.primitive.purple.600}" },
      "hover":   { "$type": "color", "$value": "{color.primitive.purple.400}" },
      "light":   { "$type": "color", "$value": "{color.primitive.purple.100}" }
    }
  }
}
