---
import '../styles/global.css';

interface Props {
  title: string;
  activeSection?: string;
  activePage?: string;
}

const { title, activeSection, activePage } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  {
    section: 'Getting Started',
    links: [
      { label: 'Introduction', href: `${base}` },
      { label: 'Installation', href: `${base}getting-started/installation/` },
    ]
  },
  {
    section: 'Foundations',
    links: [
      { label: 'Colors', href: `${base}foundations/colors/` },
      { label: 'Typography', href: `${base}foundations/typography/` },
      { label: 'Spacing', href: `${base}foundations/spacing/` },
      { label: 'Border Radius', href: `${base}foundations/radius/` },
      { label: 'Elevation', href: `${base}foundations/elevation/` },
    ]
  },
  {
    section: 'Guidelines',
    links: [
      { label: 'Accessibility', href: `${base}guidelines/accessibility/` },
      { label: 'States', href: `${base}guidelines/states/` },
      { label: "Do's & Don'ts", href: `${base}guidelines/dos-and-donts/` },
    ]
  },
  {
    section: 'Components',
    links: [
      { label: 'Icons', href: `${base}components/icons/` },
      { label: 'Button', href: `${base}components/button/` },
      { label: 'Card', href: `${base}components/card/` },
      { label: 'Input', href: `${base}components/input/` },
      { label: 'Navigation', href: `${base}components/navigation/` },
      { label: 'Ticker', href: `${base}components/ticker/` },
      { label: 'Contact List', href: `${base}components/contact-list/` },
      { label: 'Review Badge', href: `${base}components/review-badge/` },
      { label: 'Footer', href: `${base}components/footer/` },
    ]
  },
];
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — QTE Design System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Mobile Header -->
  <header class="docs-mobile-header">
    <a href={base} class="docs-mobile-header__logo">QTE Design System</a>
    <button class="docs-mobile-header__toggle" aria-label="Toggle navigation" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  <!-- Sidebar Overlay -->
  <div class="docs-sidebar-overlay"></div>

  <div class="docs-layout">
    <aside class="docs-sidebar">
      <a href={base} class="docs-sidebar__logo">QTE Design System</a>
      {nav.map(group => (
        <div class="docs-sidebar__section">
          <div class="docs-sidebar__section-title">{group.section}</div>
          {group.links.map(link => (
            <a
              href={link.href}
              class={`docs-sidebar__link ${activePage === link.label ? 'docs-sidebar__link--active' : ''}`}
            >
              {link.label}
            </a>
          ))}
        </div>
      ))}
    </aside>
    <main class="docs-main">
      <slot />
    </main>
  </div>

  <script is:inline>
    // Mobile sidebar toggle
    (function() {
      var toggle = document.querySelector('.docs-mobile-header__toggle');
      var sidebar = document.querySelector('.docs-sidebar');
      var overlay = document.querySelector('.docs-sidebar-overlay');
      if (!toggle || !sidebar || !overlay) return;

      function openMenu() {
        sidebar.setAttribute('data-open', 'true');
        overlay.setAttribute('data-open', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        sidebar.removeAttribute('data-open');
        overlay.removeAttribute('data-open');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', function() {
        var isOpen = sidebar.getAttribute('data-open') === 'true';
        if (isOpen) closeMenu(); else openMenu();
      });

      overlay.addEventListener('click', closeMenu);

      // Close on link click (mobile)
      sidebar.querySelectorAll('.docs-sidebar__link').forEach(function(link) {
        link.addEventListener('click', closeMenu);
      });
    })();

    // Copy button functionality
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.code-block__copy');
      if (!btn) return;
      var code = btn.closest('.code-block').querySelector('code');
      navigator.clipboard.writeText(code.textContent).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
      });
    });
  </script>
</body>
</html>
