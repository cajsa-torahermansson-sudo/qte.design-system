---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Elevation" activePage="Elevation">
  <h1>Elevation</h1>
  <p>Four shadow levels using purple-tinted box shadows. Used to create depth hierarchy across cards and overlays.</p>

  <h2>Scale</h2>
  <table class="props-table">
    <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
    <tbody>
      <tr><td><code>--shadow-sm</code></td><td>0 1px 3px 0 rgba(0,0,0,0.05)</td><td>Subtle lift — inputs, small cards</td></tr>
      <tr><td><code>--shadow-md</code></td><td>0 2px 17px 0 rgba(151,71,255,0.13)</td><td>Default card shadow, ticker cards</td></tr>
      <tr><td><code>--shadow-lg</code></td><td>0 8px 24px -4px rgba(151,71,255,0.08)</td><td>Elevated cards, dropdown menus</td></tr>
      <tr><td><code>--shadow-xl</code></td><td>0 20px 40px -8px rgba(151,71,255,0.12)</td><td>Modals, popovers, hover effects</td></tr>
    </tbody>
  </table>

  <h2>Visual Demo</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 32px; margin-top: 16px;">
    {[
      { label: 'sm', shadow: '0 1px 3px 0 rgba(0,0,0,0.05)' },
      { label: 'md', shadow: '0 2px 17px 0 rgba(151,71,255,0.13)' },
      { label: 'lg', shadow: '0 8px 24px -4px rgba(151,71,255,0.08)' },
      { label: 'xl', shadow: '0 20px 40px -8px rgba(151,71,255,0.12)' },
    ].map(s => (
      <div style={`padding: 32px 24px; border-radius: 10px; background-color: #fff; box-shadow: ${s.shadow}; text-align: center;`}>
        <div style="font-weight: 700; font-size: 16px; margin-bottom: 4px;">--shadow-{s.label}</div>
        <div style="font-size: 12px; color: var(--color-text-body, #5F5273);">{s.shadow}</div>
      </div>
    ))}
  </div>

  <h2>Usage</h2>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`.card {
  box-shadow: var(--shadow-md);
}

.card:hover {
  box-shadow: var(--shadow-lg);
}

.modal {
  box-shadow: var(--shadow-xl);
}`}</code>
  </div>
</DocsLayout>
