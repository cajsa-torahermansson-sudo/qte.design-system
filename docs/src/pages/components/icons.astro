---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Icons" activePage="Icons">
  <style is:global>
    .icon-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: var(--spacing-md);
      margin: var(--spacing-md) 0 var(--spacing-xl);
    }
    .icon-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-sm);
      padding: var(--spacing-md);
      border-radius: var(--radius-lg);
      background-color: var(--color-bg-primary);
      transition: var(--transition-default);
    }
    .icon-card:hover {
      background-color: var(--color-bg-secondary);
    }
    .icon-card svg {
      width: 24px;
      height: 24px;
      stroke: var(--color-text-heading);
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      fill: none;
    }
    .icon-card--filled svg {
      fill: var(--color-text-heading);
      stroke: none;
    }
    .icon-card__label {
      font-size: 11px;
      color: var(--color-text-body);
      text-align: center;
    }
  </style>

  <h1>Icons</h1>
  <p>Core icon set for the QTE Design System. All icons are 24×24px, stroke-based (2px weight, round caps). Use as inline SVGs or import from the Figma library via INSTANCE_SWAP.</p>

  <h2>Navigation</h2>
  <div class="icon-grid">
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>
      <span class="icon-card__label">Chevron Right</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M15 6l-6 6 6 6"/></svg>
      <span class="icon-card__label">Chevron Left</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
      <span class="icon-card__label">Chevron Down</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M5 12h14M14 7l5 5-5 5"/></svg>
      <span class="icon-card__label">Arrow Right</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M19 12H5M10 7l-5 5 5 5"/></svg>
      <span class="icon-card__label">Arrow Left</span>
    </div>
  </div>

  <h2>Actions</h2>
  <div class="icon-grid">
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
      <span class="icon-card__label">Close</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      <span class="icon-card__label">Menu</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><circle cx="10.5" cy="10.5" r="7.5"/><path d="M16 16l5 5"/></svg>
      <span class="icon-card__label">Search</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
      <span class="icon-card__label">External Link</span>
    </div>
  </div>

  <h2>Communication</h2>
  <div class="icon-grid">
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M3 5h18v14H3zM3 5l9 8 9-8"/></svg>
      <span class="icon-card__label">Mail</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M5 4h4l2 5-2.5 1.5a11.65 11.65 0 005 5L15 13l5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"/></svg>
      <span class="icon-card__label">Phone</span>
    </div>
  </div>

  <h2>Media</h2>
  <div class="icon-grid">
    <div class="icon-card icon-card--filled">
      <svg viewBox="0 0 24 24"><path d="M8 5l12 7-12 7z"/></svg>
      <span class="icon-card__label">Play</span>
    </div>
    <div class="icon-card icon-card--filled">
      <svg viewBox="0 0 24 24"><rect x="7" y="4" width="3" height="16"/><rect x="14" y="4" width="3" height="16"/></svg>
      <span class="icon-card__label">Pause</span>
    </div>
  </div>

  <h2>Status</h2>
  <div class="icon-grid">
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M4 12l5 5L20 6"/></svg>
      <span class="icon-card__label">Check</span>
    </div>
    <div class="icon-card icon-card--filled">
      <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14l-5-4.87 6.91-1.01z"/></svg>
      <span class="icon-card__label">Star</span>
    </div>
  </div>

  <h2>Utility</h2>
  <div class="icon-grid">
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      <span class="icon-card__label">Calendar</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
      <span class="icon-card__label">Location</span>
    </div>
    <div class="icon-card">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2c2.5 2.73 4 6.24 4 10s-1.5 7.27-4 10M12 2c-2.5 2.73-4 6.24-4 10s1.5 7.27 4 10"/></svg>
      <span class="icon-card__label">Globe</span>
    </div>
  </div>

  <h2>Alert</h2>
  <p>Warning, error, info, and status indicators.</p>
  <div class="icon-grid">
    <div class="icon-card icon-card--filled"><svg viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 6v6m0 2v2"/></svg><span class="icon-card__label">circle-exclamation</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg><span class="icon-card__label">circle-info</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9 9a3 3 0 015.12 2.13c0 1.87-2.62 2.37-2.62 4.37M12 17h.01"/></svg><span class="icon-card__label">circle-question</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg><span class="icon-card__label">circle-check</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/></svg><span class="icon-card__label">triangle-warning</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M12 4v8M12 16v2"/></svg><span class="icon-card__label">exclamation</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M12 8v4M12 16h.01M7.86 2h8.28L22 7.86v8.28L16.14 22H7.86L2 16.14V7.86L7.86 2z"/></svg><span class="icon-card__label">octagon-alert</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM12 8v4M12 16h.01"/></svg><span class="icon-card__label">shield-alert</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0M12 2v2"/></svg><span class="icon-card__label">bell-alert</span></div>
  </div>

  <h2>Arrows</h2>
  <p>Directional arrows, sorting, navigation, and data flow indicators.</p>
  <div class="icon-grid">
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12l7-7 7 7"/></svg><span class="icon-card__label">arrow-up</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7 7 7-7"/></svg><span class="icon-card__label">arrow-down</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg><span class="icon-card__label">arrow-left</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg><span class="icon-card__label">arrow-right</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg><span class="icon-card__label">arrow-up-right</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M17 7L7 17M7 17h10M7 17V7"/></svg><span class="icon-card__label">arrow-down-left</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M6 9l6-6 6 6"/></svg><span class="icon-card__label">chevron-up</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M7 17V7M17 7v10M12 3v18"/></svg><span class="icon-card__label">arrows-up-down</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M17 7H7M7 17h10M3 12h18"/></svg><span class="icon-card__label">arrows-left-right</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg><span class="icon-card__label">refresh</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 11-6.22-8.56"/><path d="M21 3v5h-5"/></svg><span class="icon-card__label">rotate</span></div>
    <div class="icon-card icon-card--filled"><svg viewBox="0 0 24 24"><path d="M12 4l-6 8h12z"/></svg><span class="icon-card__label">sort-up</span></div>
    <div class="icon-card icon-card--filled"><svg viewBox="0 0 24 24"><path d="M12 20l6-8H6z"/></svg><span class="icon-card__label">sort-down</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg><span class="icon-card__label">download</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg><span class="icon-card__label">upload</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg><span class="icon-card__label">expand</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M4 14h6v6M20 10h-6V4M14 10l7-7M3 21l7-7"/></svg><span class="icon-card__label">minimize</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M9 10l-5 5 5 5"/><path d="M20 4v7a4 4 0 01-4 4H4"/></svg><span class="icon-card__label">reply</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg><span class="icon-card__label">shuffle</span></div>
  </div>

  <h2>Calendar</h2>
  <p>Date, time, scheduling, and event management.</p>
  <div class="icon-grid">
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg><span class="icon-card__label">calendar</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M9 16l2 2 4-4"/></svg><span class="icon-card__label">calendar-check</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4"/></svg><span class="icon-card__label">calendar-plus</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M10 16h4"/></svg><span class="icon-card__label">calendar-minus</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M12 14v2M12 18h.01"/></svg><span class="icon-card__label">calendar-alert</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><circle cx="12" cy="16" r="2"/></svg><span class="icon-card__label">calendar-user</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg><span class="icon-card__label">clock</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6"/><path d="M16.24 7.76l-2.12 2.12"/></svg><span class="icon-card__label">timer</span></div>
  </div>

  <h2>Communication</h2>
  <p>Messaging, email, phone, and social interaction.</p>
  <div class="icon-grid">
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M3 5h18v14H3zM3 5l9 8 9-8"/></svg><span class="icon-card__label">mail</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M3 9l9 6 9-6M21 9v10H3V9"/></svg><span class="icon-card__label">mail-open</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M3 5h18v14H3zM3 5l9 8 9-8"/><path d="M15 12l2 2 4-4"/></svg><span class="icon-card__label">mail-check</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4z"/></svg><span class="icon-card__label">send</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg><span class="icon-card__label">message-circle</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg><span class="icon-card__label">message-square</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M5 4h4l2 5-2.5 1.5a11.65 11.65 0 005 5L15 13l5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"/></svg><span class="icon-card__label">phone</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M16 2l-4 4 4 4"/><path d="M20 10V6h-4M5 4h4l2 5-2.5 1.5a11.65 11.65 0 005 5L15 13l5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"/></svg><span class="icon-card__label">phone-incoming</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 12h10M7 8h6"/></svg><span class="icon-card__label">inbox</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 006 0v-1a10 10 0 10-3.92 7.94"/></svg><span class="icon-card__label">at-sign</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><path d="M8 10h8M8 14h4"/></svg><span class="icon-card__label">chat</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/></svg><span class="icon-card__label">share</span></div>
    <div class="icon-card"><svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg><span class="icon-card__label">link</span></div>
  </div>

  <h2>Usage</h2>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`<!-- Inline SVG (recommended) -->
<svg width="24" height="24" viewBox="0 0 24 24"
  fill="none" stroke="currentColor" stroke-width="2"
  stroke-linecap="round" stroke-linejoin="round">
  <path d="M9 6l6 6-6 6"/>
</svg>

<!-- Icons inherit color from parent via currentColor -->
<a href="/next" style="color: var(--color-accent-primary)">
  Next <svg ...><path d="M5 12h14M14 7l5 5-5 5"/></svg>
</a>

<!-- In Figma: use INSTANCE_SWAP on any Icon/ component -->`}</code>
  </div>

  <h2>Specs</h2>
  <table class="props-table">
    <thead><tr><th>Property</th><th>Value</th></tr></thead>
    <tbody>
      <tr><td>Size</td><td>24 × 24px</td></tr>
      <tr><td>Stroke width</td><td>2px</td></tr>
      <tr><td>Stroke cap</td><td>Round</td></tr>
      <tr><td>Stroke join</td><td>Round</td></tr>
      <tr><td>Color</td><td>currentColor (inherits from parent)</td></tr>
      <tr><td>Filled icons</td><td>Play, Pause, Star — use fill instead of stroke</td></tr>
    </tbody>
  </table>
</DocsLayout>
