---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Installation" activePage="Installation">
  <h1>Installation</h1>
  <p>Get started with QTE Design System in any project.</p>

  <h2>npm</h2>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>npm install @qte/design-system</code>
  </div>

  <h2>CDN</h2>
  <p>Use directly from a CDN without installing:</p>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`<link rel="stylesheet" href="https://unpkg.com/@qte/design-system/css/tokens.css" />
<link rel="stylesheet" href="https://unpkg.com/@qte/design-system/styles/button.css" />`}</code>
  </div>

  <h2>Import Tokens Only</h2>
  <p>If you only need design tokens (colors, spacing, etc.):</p>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`/* CSS */
@import '@qte/design-system/tokens.css';

/* Then use tokens in your own styles */
.my-header {
  background-color: var(--color-bg-dark);
  color: var(--color-text-on-dark);
  padding: var(--spacing-lg);
}`}</code>
  </div>

  <h2>Import Component Styles</h2>
  <p>Import individual component CSS files as needed:</p>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`@import '@qte/design-system/tokens.css';      /* Required */
@import '@qte/design-system/styles/button.css';
@import '@qte/design-system/styles/card.css';
@import '@qte/design-system/styles/input.css';`}</code>
  </div>

  <h2>Dark Mode</h2>
  <p>Add <code>data-theme="dark"</code> or class <code>.dark</code> to any parent element:</p>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`<!-- Entire page in dark mode -->
<html data-theme="dark">

<!-- Section in dark mode -->
<section class="dark">
  <h2>This section uses dark mode tokens</h2>
</section>

<!-- Toggle with JavaScript -->
<script>
  document.documentElement.setAttribute('data-theme',
    window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
  );
</script>`}</code>
  </div>

  <h2>Framework Examples</h2>

  <h3>React / Next.js</h3>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`// globals.css or layout.tsx
import '@qte/design-system/css/tokens.css';
import '@qte/design-system/styles/button.css';

// Component
export function ContactButton() {
  return <button className="qte-btn qte-btn--primary">Boka möte</button>
}`}</code>
  </div>

  <h3>Vue / Nuxt</h3>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`<!-- nuxt.config or main.css -->
@import '@qte/design-system/css/tokens.css';
@import '@qte/design-system/styles/button.css';

<!-- Component -->
<template>
  <button class="qte-btn qte-btn--primary">Boka möte</button>
</template>`}</code>
  </div>

  <h3>Svelte</h3>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`<!-- +layout.svelte or app.css -->
@import '@qte/design-system/css/tokens.css';
@import '@qte/design-system/styles/button.css';

<!-- Component -->
<button class="qte-btn qte-btn--primary">Boka möte</button>`}</code>
  </div>

  <h3>Plain HTML</h3>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`<!DOCTYPE html>
<html lang="sv">
<head>
  <link rel="stylesheet" href="path/to/tokens.css" />
  <link rel="stylesheet" href="path/to/styles/button.css" />
</head>
<body>
  <button class="qte-btn qte-btn--primary">Boka möte</button>
</body>
</html>`}</code>
  </div>
  <h2>iOS (SwiftUI)</h2>
  <p>Copy <code>tokens.swift</code> into your Xcode project. All colors, spacing, radius, and typography are available as static properties.</p>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`// Copy css/tokens.swift into your project

import SwiftUI

struct MyButton: View {
    var body: some View {
        Button("Boka möte") { }
            .padding(.horizontal, QTESpacing.xl)
            .padding(.vertical, QTESpacing.sm)
            .background(Color.QTE.Light.accentPrimary)
            .foregroundColor(Color.QTE.Light.textOnDark)
            .clipShape(Capsule())
            .font(.custom(QTETypography.fontFamily, size: QTETypography.Size.sm))
            .fontWeight(.bold)
    }
}

// Dark mode — use Color.QTE.Dark instead
struct MyDarkButton: View {
    var body: some View {
        Button("Boka möte") { }
            .background(Color.QTE.Dark.accentPrimary)
            .foregroundColor(Color.QTE.Dark.textOnDark)
    }
}`}</code>
  </div>

  <h2>Android (Jetpack Compose)</h2>
  <p>Copy <code>tokens.kt</code> into your project under your design system package. Tokens use Compose types (<code>dp</code>, <code>sp</code>, <code>Color</code>).</p>
  <div class="code-block">
    <button class="code-block__copy">Copy</button>
    <code>{`// Copy css/tokens.kt into se/qte/designsystem/

import se.qte.designsystem.*

@Composable
fun QTEButton(text: String, onClick: () -> Unit) {
    Button(
        onClick = onClick,
        shape = RoundedCornerShape(QTERadius.full),
        colors = ButtonDefaults.buttonColors(
            containerColor = QTEColor.Light.accentPrimary,
            contentColor = QTEColor.Light.textOnDark
        ),
        contentPadding = PaddingValues(
            horizontal = QTESpacing.xl,
            vertical = QTESpacing.sm
        )
    ) {
        Text(
            text = text,
            fontSize = QTETypography.Size.sm,
            fontWeight = FontWeight(QTETypography.Weight.bold)
        )
    }
}

// Dark mode — use QTEColor.Dark
@Composable
fun QTEDarkButton(text: String, onClick: () -> Unit) {
    Button(
        onClick = onClick,
        colors = ButtonDefaults.buttonColors(
            containerColor = QTEColor.Dark.accentPrimary
        )
    ) { Text(text) }
}`}</code>
  </div>

  <h2>Platform Token Files</h2>
  <table class="props-table">
    <thead><tr><th>Platform</th><th>File</th><th>Format</th></tr></thead>
    <tbody>
      <tr><td>Web</td><td><code>css/tokens.css</code></td><td>CSS Custom Properties</td></tr>
      <tr><td>iOS</td><td><code>css/tokens.swift</code></td><td>SwiftUI Color/CGFloat extensions</td></tr>
      <tr><td>Android</td><td><code>css/tokens.kt</code></td><td>Jetpack Compose Color/dp/sp objects</td></tr>
      <tr><td>Source</td><td><code>tokens/*.json</code></td><td>DTCG format (for custom transforms)</td></tr>
    </tbody>
  </table>
</DocsLayout>
